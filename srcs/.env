
# 1. L'URL "interne" (Symfony -> Mercure)
# Symfony parle au conteneur voisin via le réseau Docker. On utilise le nom du service Docker.
MERCURE_URL=http://mercure/.well-known/mercure
MERCURE_PUBLIC_URL=http://localhost:9090/.well-known/mercure
MERCURE_JWT_SECRET=your_super_secret_jwt_key_min_32_chars!!